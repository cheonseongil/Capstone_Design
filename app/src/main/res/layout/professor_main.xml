<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/main" android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="#FAFAFA">



    <ImageView

        android:id="@+id/iv_settings"

        android:layout_width="28dp"

        android:layout_height="28dp"

        android:layout_marginStart="24dp"

        android:layout_marginTop="32dp"

        android:src="@drawable/setting"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toTopOf="parent" />



    <LinearLayout

        android:id="@+id/ll_profile"

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:layout_marginTop="20dp"

        android:gravity="center"

        android:orientation="vertical"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toTopOf="parent">



        <ImageView

            android:layout_width="48dp"

            android:layout_height="48dp"

            android:src="@drawable/user" />





        <TextView

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="8dp"

            android:text="교수"

            android:textColor="#000000"

            android:textSize="14sp"

            android:textStyle="bold" />

    </LinearLayout>



    <LinearLayout

        android:layout_width="0dp"

        android:layout_height="41dp"

        android:layout_marginTop="24dp"

        android:layout_marginEnd="24dp"

        android:gravity="center"

        android:orientation="vertical"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintTop_toTopOf="parent">





    </LinearLayout>



    <View

        android:id="@+id/v_divider"

        android:layout_width="0dp"

        android:layout_height="1dp"

        android:layout_marginHorizontal="24dp"

        android:layout_marginTop="16dp"

        android:background="#999999"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toBottomOf="@id/ll_profile" />



    <LinearLayout

        android:layout_width="0dp"

        android:layout_height="wrap_content"

        android:layout_marginHorizontal="40dp"

        android:layout_marginTop="32dp"

        android:orientation="vertical"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toBottomOf="@id/v_divider">



        <LinearLayout

            android:id="@+id/btn_daily_attendance"

            android:layout_width="match_parent"

            android:layout_height="80dp"

            android:layout_marginBottom="24dp"

            android:background="@drawable/bg_rounded_button"

            android:elevation="4dp"

            android:gravity="center_vertical"

            android:paddingHorizontal="32dp">



            <ImageView

                android:layout_width="48dp"

                android:layout_height="48dp"

                android:src="@drawable/daily_attendance" />



            <TextView

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:layout_marginStart="24dp"

                android:text="일일출석"

                android:textColor="#000000"

                android:textSize="22sp" />

        </LinearLayout>



        <LinearLayout

            android:id="@+id/btn_attendance_rate" android:layout_width="match_parent"

            android:layout_height="80dp"

            android:layout_marginBottom="24dp"

            android:background="@drawable/bg_rounded_button"

            android:elevation="4dp"

            android:gravity="center_vertical"

            android:paddingHorizontal="32dp">



            <ImageView

                android:layout_width="48dp"

                android:layout_height="48dp"

                android:src="@drawable/graph" />



            <TextView

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:layout_marginStart="24dp"

                android:text="출석 관리"

                android:textColor="#000000"

                android:textSize="22sp" />

        </LinearLayout>



        <LinearLayout

            android:layout_width="match_parent"

            android:layout_height="80dp"

            android:background="@drawable/bg_rounded_button"

            android:elevation="4dp"

            android:gravity="center_vertical"

            android:paddingHorizontal="32dp">



            <ImageView

                android:layout_width="48dp"

                android:layout_height="48dp"

                android:src="@drawable/course_taken" />



            <TextView

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:layout_marginStart="24dp"

                android:text="강의 과목"

                android:textColor="#000000"

                android:textSize="22sp" />

        </LinearLayout>



    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>