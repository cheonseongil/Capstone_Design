<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/iv_bg_watermark"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:src="@drawable/semyung_logo"
        android:alpha="0.05"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="60dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/go_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/graph"
                android:rotation="180"
                app:tint="#4CAF50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="네트워크 출석률"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_chart"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/layout_header">

        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_100" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.0" />
        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_80" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.2" />
        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_60" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.4" />
        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_40" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.6" />
        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_20" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.8" />
        <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="1.0" />

        <TextView android:id="@+id/tv_100" android:layout_width="24dp" android:layout_height="wrap_content" android:text="100" android:textSize="10sp" android:textColor="#000" app:layout_constraintBottom_toBottomOf="@id/gl_100" app:layout_constraintTop_toTopOf="@id/gl_100" app:layout_constraintStart_toStartOf="parent"/>
        <View android:layout_width="0dp" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="8dp" app:layout_constraintTop_toTopOf="@id/gl_100" app:layout_constraintStart_toEndOf="@id/tv_100" app:layout_constraintEnd_toEndOf="parent"/>
        <TextView android:id="@+id/tv_80" android:layout_width="24dp" android:layout_height="wrap_content" android:text="80" android:textSize="10sp" android:textColor="#000" app:layout_constraintBottom_toBottomOf="@id/gl_80" app:layout_constraintTop_toTopOf="@id/gl_80" app:layout_constraintStart_toStartOf="parent"/>
        <View android:layout_width="0dp" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="8dp" app:layout_constraintTop_toTopOf="@id/gl_80" app:layout_constraintStart_toEndOf="@id/tv_80" app:layout_constraintEnd_toEndOf="parent"/>
        <TextView android:id="@+id/tv_60" android:layout_width="24dp" android:layout_height="wrap_content" android:text="60" android:textSize="10sp" android:textColor="#000" app:layout_constraintBottom_toBottomOf="@id/gl_60" app:layout_constraintTop_toTopOf="@id/gl_60" app:layout_constraintStart_toStartOf="parent"/>
        <View android:layout_width="0dp" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="8dp" app:layout_constraintTop_toTopOf="@id/gl_60" app:layout_constraintStart_toEndOf="@id/tv_60" app:layout_constraintEnd_toEndOf="parent"/>
        <TextView android:id="@+id/tv_40" android:layout_width="24dp" android:layout_height="wrap_content" android:text="40" android:textSize="10sp" android:textColor="#000" app:layout_constraintBottom_toBottomOf="@id/gl_40" app:layout_constraintTop_toTopOf="@id/gl_40" app:layout_constraintStart_toStartOf="parent"/>
        <View android:layout_width="0dp" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="8dp" app:layout_constraintTop_toTopOf="@id/gl_40" app:layout_constraintStart_toEndOf="@id/tv_40" app:layout_constraintEnd_toEndOf="parent"/>
        <TextView android:id="@+id/tv_20" android:layout_width="24dp" android:layout_height="wrap_content" android:text="20" android:textSize="10sp" android:textColor="#000" app:layout_constraintBottom_toBottomOf="@id/gl_20" app:layout_constraintTop_toTopOf="@id/gl_20" app:layout_constraintStart_toStartOf="parent"/>
        <View android:layout_width="0dp" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="8dp" app:layout_constraintTop_toTopOf="@id/gl_20" app:layout_constraintStart_toEndOf="@id/tv_20" app:layout_constraintEnd_toEndOf="parent"/>
        <View android:layout_width="0dp" android:layout_height="1dp" android:background="#BDBDBD" android:layout_marginStart="8dp" app:layout_constraintTop_toTopOf="@id/gl_0" app:layout_constraintStart_toEndOf="@id/tv_20" app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/bar_attend"
            android:layout_width="36dp"
            android:layout_height="0dp"
            android:background="#4CAF50"
            app:layout_constraintBottom_toBottomOf="@id/gl_0"
            app:layout_constraintHeight_percent="0.6"
            app:layout_constraintEnd_toStartOf="@id/bar_late"
            app:layout_constraintStart_toEndOf="@id/tv_40" />

        <View
            android:id="@+id/bar_late"
            android:layout_width="36dp"
            android:layout_height="0dp"
            android:background="#FFEB3B"
            app:layout_constraintBottom_toBottomOf="@id/gl_0"
            app:layout_constraintHeight_percent="0.1"
            app:layout_constraintEnd_toStartOf="@id/bar_absent"
            app:layout_constraintStart_toEndOf="@id/bar_attend" />

        <View
            android:id="@+id/bar_absent"
            android:layout_width="36dp"
            android:layout_height="0dp"
            android:background="#F44336"
            app:layout_constraintBottom_toBottomOf="@id/gl_0"
            app:layout_constraintHeight_percent="0.2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/bar_late" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="출석"
        android:textSize="12sp"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/layout_chart"
        app:layout_constraintStart_toStartOf="@id/layout_chart"
        app:layout_constraintEnd_toStartOf="@id/tv_label_late"
        app:layout_constraintHorizontal_bias="0.25"/> <TextView
    android:id="@+id/tv_label_late"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="지각"
    android:textSize="12sp"
    android:textColor="#000000"
    app:layout_constraintTop_toBottomOf="@id/layout_chart"
    app:layout_constraintStart_toStartOf="@id/layout_chart"
    app:layout_constraintEnd_toEndOf="@id/layout_chart"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="결석"
        android:textSize="12sp"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/layout_chart"
        app:layout_constraintStart_toEndOf="@id/tv_label_late"
        app:layout_constraintEnd_toEndOf="@id/layout_chart"
        app:layout_constraintHorizontal_bias="0.75"/> <androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginTop="40dp"
    app:cardBackgroundColor="#FAFAFA"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:layout_constraintTop_toBottomOf="@id/layout_chart">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_outline_button"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/icon_bottom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="#EDE7F6"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="N"
                android:textColor="#5E35B1"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_summary_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="네트워크"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/icon_bottom"
            app:layout_constraintTop_toTopOf="@id/icon_bottom" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="출석 60% / 지각 10% / 결석 20%"
            android:textColor="#666666"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_summary_title"
            app:layout_constraintTop_toBottomOf="@id/tv_summary_title" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>