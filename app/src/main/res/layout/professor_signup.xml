<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".LoginActivity">

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="112dp"
        android:layout_height="114dp"
        android:layout_marginTop="76dp"
        android:scaleType="fitCenter"
        android:src="@drawable/semyung_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.481"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="교수 로그인"
        android:textColor="#000000"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.15" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_edit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.38" />

    <TextView
        android:id="@+id/labelId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:text="아이디"
        android:textColor="#000000"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="@id/guide_label" />

    <EditText
        android:id="@+id/editId"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginEnd="40dp"
        android:background="@null"
        android:hint="아이디 입력"
        android:inputType="text"
        app:layout_constraintBottom_toBottomOf="@id/labelId"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/guide_edit" />

    <View
        android:id="@+id/lineId"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#B2B2B2"
        app:layout_constraintTop_toBottomOf="@id/editId"
        app:layout_constraintStart_toStartOf="@id/editId"
        app:layout_constraintEnd_toEndOf="@id/editId" />

    <TextView
        android:id="@+id/labelPw"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="비밀번호"
        android:textColor="#000000"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/labelId"
        app:layout_constraintStart_toStartOf="@id/guide_label" />

    <EditText
        android:id="@+id/editPw"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginEnd="40dp"
        android:background="@null"
        android:hint="비밀번호 입력"
        android:inputType="textPassword"
        app:layout_constraintBottom_toBottomOf="@id/labelPw"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/guide_edit" />

    <View
        android:id="@+id/linePw"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#B2B2B2"
        app:layout_constraintTop_toBottomOf="@id/editPw"
        app:layout_constraintStart_toStartOf="@id/editPw"
        app:layout_constraintEnd_toEndOf="@id/editPw" />

    <CheckBox
        android:id="@+id/checkStayLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="로그인 상태 유지"
        android:textColor="#666666"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/linePw"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="160dp"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="#0088FF"
        android:text="로그인"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/checkStayLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>