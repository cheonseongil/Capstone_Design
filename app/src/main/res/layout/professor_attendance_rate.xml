<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/go_back"
        android:padding="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="20dp" />

    <LinearLayout
        android:id="@+id/ll_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        app:layout_constraintBottom_toBottomOf="@id/btn_back">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/daily_attendance" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="일일 출석"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:id="@+id/v_header_line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/btn_back" />

    <!-- ★ 수정됨: clipChildren="false" 추가 (텍스트가 위로 올라가도 안 잘림) -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/v_header_line"
        app:layout_constraintBottom_toBottomOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:paddingBottom="50dp">

            <!-- 1. 좌측 시간 텍스트 영역 (clipChildren 추가) -->
            <LinearLayout
                android:id="@+id/ll_time_column"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:orientation="vertical" />

            <!-- 2. 우측 그리드 및 과목 블록 영역 -->
            <RelativeLayout
                android:id="@+id/rl_event_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/ll_time_column">

                <!-- 가로줄(그리드)이 들어갈 곳 -->
                <LinearLayout
                    android:id="@+id/ll_grid_lines"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- 이 안에 Java 코드로 과목 블록이 추가됩니다 -->
            </RelativeLayout>

            <!-- 3. 현재 시간 표시 빨간색 실선 (최상단 겹침) -->
            <LinearLayout
                android:id="@+id/layout_current_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="invisible">

                <!-- 실시간 텍스트 -->
                <TextView
                    android:id="@+id/tv_current_time"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="12:31"
                    android:textColor="#D32F2F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!-- 빨간 점 -->
                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_circle_red" />

                <!-- 빨간 가로 실선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#D32F2F" />
            </LinearLayout>

        </RelativeLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>