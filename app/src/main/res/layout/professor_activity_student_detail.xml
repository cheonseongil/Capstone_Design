<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/go_back"
            android:padding="4dp"/>

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/graph" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="출석 관리"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="예)20xx/xx/xx"
            android:textColor="#000000"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:src="@drawable/semyung_logo"
        android:alpha="0.05"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header_layout"
        app:layout_constraintBottom_toBottomOf="parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_student_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="16dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/user" />

                <TextView
                    android:id="@+id/tv_detail_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="20xxxxxxxx"
                    android:textColor="#333333"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tv_detail_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="홍길동"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_faq_card"
                android:padding="20dp"
                android:layout_marginBottom="24dp"
                android:weightSum="4">

                <TextView
                    android:id="@+id/tv_total_present"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="출석: 0"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tv_total_late"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="지각: 0"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tv_total_yugo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="유고: 0"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tv_total_absent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="결석: 0"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_faq_card" android:padding="16dp" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2026.03.05 09:29:26 " android:textColor="#000" android:textStyle="bold" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_record_status_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="출석" android:textColor="#4CAF50" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:orientation="horizontal">
                    <TextView android:id="@+id/btn_present_1" android:layout_width="60dp" android:layout_height="36dp" android:background="@drawable/bg_btn_present" android:gravity="center" android:text="출석" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_late_1" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_late" android:gravity="center" android:text="지각" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_yugo_1" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_yugo" android:gravity="center" android:text="유고" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_absent_1" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_absent" android:gravity="center" android:text="결석" android:textColor="#FFFFFF" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_faq_card" android:padding="16dp" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2026.03.12 09:45:26 " android:textColor="#000" android:textStyle="bold" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_record_status_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="지각" android:textColor="#FF7043" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:orientation="horizontal">
                    <TextView android:id="@+id/btn_present_2" android:layout_width="60dp" android:layout_height="36dp" android:background="@drawable/bg_btn_present" android:gravity="center" android:text="출석" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_late_2" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_late" android:gravity="center" android:text="지각" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_yugo_2" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_yugo" android:gravity="center" android:text="유고" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_absent_2" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_absent" android:gravity="center" android:text="결석" android:textColor="#FFFFFF" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_faq_card" android:padding="16dp" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2026.03.19 09:28:10 " android:textColor="#000" android:textStyle="bold" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_record_status_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="출석" android:textColor="#4CAF50" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:orientation="horizontal">
                    <TextView android:id="@+id/btn_present_3" android:layout_width="60dp" android:layout_height="36dp" android:background="@drawable/bg_btn_present" android:gravity="center" android:text="출석" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_late_3" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_late" android:gravity="center" android:text="지각" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_yugo_3" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_yugo" android:gravity="center" android:text="유고" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_absent_3" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_absent" android:gravity="center" android:text="결석" android:textColor="#FFFFFF" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_faq_card" android:padding="16dp" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2026.03.26 10:15:00 " android:textColor="#000" android:textStyle="bold" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_record_status_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="결석" android:textColor="#D32F2F" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:orientation="horizontal">
                    <TextView android:id="@+id/btn_present_4" android:layout_width="60dp" android:layout_height="36dp" android:background="@drawable/bg_btn_present" android:gravity="center" android:text="출석" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_late_4" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_late" android:gravity="center" android:text="지각" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_yugo_4" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_yugo" android:gravity="center" android:text="유고" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_absent_4" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_absent" android:gravity="center" android:text="결석" android:textColor="#FFFFFF" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_faq_card" android:padding="16dp" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2026.04.02 09:30:05 " android:textColor="#000" android:textStyle="bold" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_record_status_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="출석" android:textColor="#4CAF50" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:orientation="horizontal">
                    <TextView android:id="@+id/btn_present_5" android:layout_width="60dp" android:layout_height="36dp" android:background="@drawable/bg_btn_present" android:gravity="center" android:text="출석" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_late_5" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_late" android:gravity="center" android:text="지각" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_yugo_5" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_yugo" android:gravity="center" android:text="유고" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:id="@+id/btn_absent_5" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_absent" android:gravity="center" android:text="결석" android:textColor="#FFFFFF" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>