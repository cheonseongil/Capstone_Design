<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp">

    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/go_back"
        android:padding="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/ll_header"
        app:layout_constraintBottom_toBottomOf="@id/ll_header" />

    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/daily_attendance" /> <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="일일 출석"
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_date_example"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="예) 2026/03/05"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_date_example">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_faq_card"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_class_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_purple"
                    android:gravity="center"
                    android:text="C"
                    android:textColor="#3F51B5"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tv_class_icon"
                    app:layout_constraintEnd_toStartOf="@id/layout_activation"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="캡스톤 디자인(4학년)"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="첨단정보학관 406호\n2026-03-05 09:30"
                        android:textColor="#333333"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_activation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="강의 활성화"
                        android:textSize="10sp"
                        android:textColor="#333333"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_pill_border">

                        <TextView
                            android:id="@+id/btn_class_start"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓ 강의 시작"
                            android:textSize="10sp"
                            android:textColor="#000000"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="6dp"
                            android:background="@drawable/bg_pill_left_filled" />

                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#D3D3D3"/>

                        <TextView
                            android:id="@+id/btn_class_end"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="강의 종료"
                            android:textSize="10sp"
                            android:textColor="#000000"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_faq_card"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:id="@+id/tv_count_present"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="출석: 0"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/tv_count_late"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="지각: 0"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/tv_count_yugo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="유고: 0"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/tv_count_absent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="결석: 0"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:gravity="center"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_faq_card"
                android:padding="16dp">

                <FrameLayout
                    android:id="@+id/fl_profile_container_1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/iv_profile_1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/user" />

                    <ImageView
                        android:id="@+id/iv_status_icon_1"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:visibility="invisible"
                        tools:src="@drawable/ic_status_present"
                        tools:visibility="visible"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="홍길동"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="@id/fl_profile_container_1"
                    app:layout_constraintStart_toStartOf="@id/fl_profile_container_1"
                    app:layout_constraintTop_toBottomOf="@id/fl_profile_container_1" />

                <TextView
                    android:id="@+id/tv_info_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:text="2024XXXXXX  2026.03.05 09:29:26"
                    android:textColor="#333333"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/fl_profile_container_1"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_status_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="출석"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tv_info_1"
                    app:layout_constraintStart_toEndOf="@id/tv_info_1"
                    app:layout_constraintTop_toTopOf="@id/tv_info_1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_info_1">

                    <TextView android:id="@+id/btn_present_1" android:layout_width="60dp" android:layout_height="36dp" android:background="@drawable/bg_btn_present" android:gravity="center" android:text="출석" android:textColor="#FFFFFF" android:textSize="14sp" />
                    <TextView android:id="@+id/btn_late_1" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_late" android:gravity="center" android:text="지각" android:textColor="#FFFFFF" android:textSize="14sp" />
                    <TextView android:id="@+id/btn_yugo_1" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_yugo" android:gravity="center" android:text="유고" android:textColor="#FFFFFF" android:textSize="14sp" />
                    <TextView android:id="@+id/btn_absent_1" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_absent" android:gravity="center" android:text="결석" android:textColor="#FFFFFF" android:textSize="14sp" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_faq_card"
                android:padding="16dp">

                <FrameLayout
                    android:id="@+id/fl_profile_container_2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/iv_profile_2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/user" />

                    <ImageView
                        android:id="@+id/iv_status_icon_2"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:visibility="invisible"
                        tools:src="@drawable/ic_status_late"
                        tools:visibility="visible"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="김길동"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="@id/fl_profile_container_2"
                    app:layout_constraintStart_toStartOf="@id/fl_profile_container_2"
                    app:layout_constraintTop_toBottomOf="@id/fl_profile_container_2" />

                <TextView
                    android:id="@+id/tv_info_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:text="2024XXXXXX  2026.03.05 09:35:26"
                    android:textColor="#333333"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/fl_profile_container_2"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_status_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="지각"
                    android:textColor="#FF7043"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tv_info_2"
                    app:layout_constraintStart_toEndOf="@id/tv_info_2"
                    app:layout_constraintTop_toTopOf="@id/tv_info_2" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_info_2">

                    <TextView android:id="@+id/btn_present_2" android:layout_width="60dp" android:layout_height="36dp" android:background="@drawable/bg_btn_present" android:gravity="center" android:text="출석" android:textColor="#FFFFFF" android:textSize="14sp" />
                    <TextView android:id="@+id/btn_late_2" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_late" android:gravity="center" android:text="지각" android:textColor="#FFFFFF" android:textSize="14sp" />
                    <TextView android:id="@+id/btn_yugo_2" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_yugo" android:gravity="center" android:text="유고" android:textColor="#FFFFFF" android:textSize="14sp" />
                    <TextView android:id="@+id/btn_absent_2" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_absent" android:gravity="center" android:text="결석" android:textColor="#FFFFFF" android:textSize="14sp" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_faq_card"
                android:padding="16dp">

                <FrameLayout
                    android:id="@+id/fl_profile_container_3"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/iv_profile_3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/user" />

                    <ImageView
                        android:id="@+id/iv_status_icon_3"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:visibility="invisible"
                        tools:src="@drawable/ic_status_absent"
                        tools:visibility="visible"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="이길동"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="@id/fl_profile_container_3"
                    app:layout_constraintStart_toStartOf="@id/fl_profile_container_3"
                    app:layout_constraintTop_toBottomOf="@id/fl_profile_container_3" />

                <TextView
                    android:id="@+id/tv_info_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:text="2024XXXXXX  2026.03.05 10:29:26"
                    android:textColor="#333333"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/fl_profile_container_3"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_status_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="결석"
                    android:textColor="#D32F2F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tv_info_3"
                    app:layout_constraintStart_toEndOf="@id/tv_info_3"
                    app:layout_constraintTop_toTopOf="@id/tv_info_3" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_info_3">

                    <TextView android:id="@+id/btn_present_3" android:layout_width="60dp" android:layout_height="36dp" android:background="@drawable/bg_btn_present" android:gravity="center" android:text="출석" android:textColor="#FFFFFF" android:textSize="14sp" />
                    <TextView android:id="@+id/btn_late_3" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_late" android:gravity="center" android:text="지각" android:textColor="#FFFFFF" android:textSize="14sp" />
                    <TextView android:id="@+id/btn_yugo_3" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_yugo" android:gravity="center" android:text="유고" android:textColor="#FFFFFF" android:textSize="14sp" />
                    <TextView android:id="@+id/btn_absent_3" android:layout_width="60dp" android:layout_height="36dp" android:layout_marginStart="8dp" android:background="@drawable/bg_btn_absent" android:gravity="center" android:text="결석" android:textColor="#FFFFFF" android:textSize="14sp" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>