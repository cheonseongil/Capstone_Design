<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="30dp"
            android:src="@drawable/semyung_logo"
            android:contentDescription="학교 로고" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="비밀번호 찾기"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <EditText
            android:id="@+id/etResetId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:hint="아이디"
            android:inputType="text"
            android:padding="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etResetContact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="전화번호 또는 본인확인 이메일"
                android:inputType="textEmailAddress"
                android:padding="12dp" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPasswordSendCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="인증번호 받기"
                android:textColor="#FFFFFF"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#0088FF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etPasswordCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="인증번호 입력"
                android:inputType="number"
                android:padding="12dp" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPasswordCodeCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="인증번호 확인"
                android:textColor="#FFFFFF"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#0088FF" />
        </LinearLayout>

        <EditText
            android:id="@+id/etNewPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="비밀번호 재설정"
            android:inputType="textPassword"
            android:padding="12dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPasswordResetDone"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="완료"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_button"
            android:backgroundTint="#0088FF" />

    </LinearLayout>
</ScrollView>